# Copy this file to .env and set the correct value for your environment.
# Expo reads variables prefixed with EXPO_PUBLIC_ at build time.

# Android emulator talking to host machine:
#EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# iOS simulator talking to host machine:
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Physical device (replace with your machine's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.XX:3000
EXPO_PUBLIC_API_URL=http://192.168.8.146:3000

